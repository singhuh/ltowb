__loadDisplayObj__f4f1e206_common_by_panel_label({"name":"by_panel_label","group":"common","desc":"","mdDesc":"","mdTitle":"Information About This Display","showMdDesc":false,"updated":"2026-04-01 12:15:43","n":108,"height":500,"width":500,"order":["function (..., na.last = TRUE, decreasing = FALSE, method = c(\"auto\", ","    \"shell\", \"radix\")) ","{","    z <- list(...)","    decreasing <- as.logical(decreasing)","    if (length(z) == 1L && is.numeric(x <- z[[1L]]) && !is.object(x) && ","        length(x) > 0) {","        if (.Internal(sorted_fpass(x, decreasing, na.last))) ","            return(seq_along(x))","    }","    method <- match.arg(method)","    if (any(vapply(z, is.object, logical(1L)))) {","        z <- lapply(z, function(x) if (is.object(x)) ","            as.vector(xtfrm(x))","        else x)","        return(do.call(\"order\", c(z, list(na.last = na.last, ","            decreasing = decreasing, method = method))))","    }","    if (method == \"auto\") {","        useRadix <- all(vapply(z, function(x) {","            (is.numeric(x) || is.factor(x) || is.logical(x)) && ","                is.integer(length(x))","        }, logical(1L)))","        method <- if (useRadix) ","            \"radix\"","        else \"shell\"","    }","    if (method != \"radix\" && !is.na(na.last)) {","        if (length(decreasing) > 1L) ","            stop(\"'decreasing' of length > 1 is only for method = \\\"radix\\\"\")","        return(.Internal(order(na.last, decreasing, ...)))","    }","    if (method == \"radix\") {","        decreasing <- rep_len(as.logical(decreasing), length(z))","        return(.Internal(radixsort(na.last, decreasing, FALSE, ","            TRUE, ...)))","    }","    if (any(diff((l.z <- lengths(z)) != 0L))) ","        stop(\"argument lengths differ\")","    na <- vapply(z, is.na, rep.int(NA, l.z[1L]))","    ok <- if (is.matrix(na)) ","        rowSums(na) == 0L","    else !any(na)","    if (all(!ok)) ","        return(integer())","    z[[1L]][!ok] <- NA","    ans <- do.call(\"order\", c(z, list(decreasing = decreasing)))","    ans[ok[ans]]","}"],"has_legend":false,"has_inputs":false,"input_type":{},"input_email":{},"input_csv_vars":{},"input_api":{},"gaID":{},"split_layout":false,"split_aspect":{},"keySig":"44451550ec8868a5f3e24804d9b0c777","cogInterface":{"name":"by_panel_label","group":"common","type":"JSON"},"panelInterface":{"type":"image"},"imgSrcLookup":{},"cogInfo":{"panel_label":{"name":"panel_label","desc":"conditioning variable","type":"factor","group":"condVar","defLabel":true,"defActive":true,"filterable":true,"log":null,"levels":["N001001140 — URMC-STRONG MEMORIAL HOSPITAL","N001003102 — GUTHRIE LOURDES HOSPITAL","N001B1AMCH — ALBANY MEDICAL CENTER HOSPITAL","N0031135 — HCA-MEMORIAL MEDICAL CENTER","N003B1KENN — WELLSTAR KENNESTONE HOSPITAL","N003B1SRMC — SOUTHERN REGIONAL MEDICAL CENTER","N003B4MCMA — ATRIUM HEALTH NAVICENT","N003B6PMID — PIEDMONT COLUMBUS REGIONAL MIDTOWN HOSP","N0041039 — MASSACHUSETTS GENERAL HOSPITAL","N0042003 — VA MEDICAL CENTER WEST ROXBURY","N0047128 — UNIVERSITY OF VERMONT MEDICAL CENTER","N0047369 — HCA-PORTSMOUTH HOSPITAL","N006B0COLA — LOS ANGELES COMMUNITY HOSPITAL","N006B3HUWA — WEST ANAHEIM MEDICAL CENTER","N006B3UCIM — UNIVERSITY OF CALIFORNIA, IRVINE MEDICAL CENTER","N006B9RRMC — RONALD REAGAN UCLA MEDICAL CENTER","N006BJANVD — ANTELOPE VALLEY MEDICAL CENTER","N006BNCEVC — CENTINELA HOSPITAL MEDICAL CENTER","N006BZKONT — KAISER PERMANENTE ONTARIO MED CTR","N006BZPKVW — DOCTORS HOSPITAL OF RIVERSIDE","N006BZRIVE — RIVERSIDE COMMUNITY HOSPITAL","N006E63SCE — SCRIPPS MEMORIAL HOSPITAL ENCINITAS","N007000115 — CANYON VISTA MEDICAL CENTER","N007000125 — TUCSON MEDICAL CENTER","N009B6NPLT — GREAT PLAINS HEALTH","N011B1BARN — BARNES-JEWISH HOSPITAL","N011B1CHNE — CHRISTIAN HOSPITAL","N011B5CARB — MEMORIAL HOSPITAL-CARBONDALE","N011B9CMEC — CENTERPOINT MEDICAL CENTER","N011B9OVER — OVERLAND PARK REGIONAL MEDICAL CENTER","N0122120 — CAPE FEAR VALLEY MEDICAL CENTER",