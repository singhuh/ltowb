__loadDisplayObj__b241a7c1_common_by_H({"name":"by_H","group":"common","desc":"","mdDesc":"","mdTitle":"Information About This Display","showMdDesc":false,"updated":"2026-04-01 12:15:31","n":20,"height":500,"width":500,"order":["function (..., na.last = TRUE, decreasing = FALSE, method = c(\"auto\", ","    \"shell\", \"radix\")) ","{","    z <- list(...)","    decreasing <- as.logical(decreasing)","    if (length(z) == 1L && is.numeric(x <- z[[1L]]) && !is.object(x) && ","        length(x) > 0) {","        if (.Internal(sorted_fpass(x, decreasing, na.last))) ","            return(seq_along(x))","    }","    method <- match.arg(method)","    if (any(vapply(z, is.object, logical(1L)))) {","        z <- lapply(z, function(x) if (is.object(x)) ","            as.vector(xtfrm(x))","        else x)","        return(do.call(\"order\", c(z, list(na.last = na.last, ","            decreasing = decreasing, method = method))))","    }","    if (method == \"auto\") {","        useRadix <- all(vapply(z, function(x) {","            (is.numeric(x) || is.factor(x) || is.logical(x)) && ","                is.integer(length(x))","        }, logical(1L)))","        method <- if (useRadix) ","            \"radix\"","        else \"shell\"","    }","    if (method != \"radix\" && !is.na(na.last)) {","        if (length(decreasing) > 1L) ","            stop(\"'decreasing' of length > 1 is only for method = \\\"radix\\\"\")","        return(.Internal(order(na.last, decreasing, ...)))","    }","    if (method == \"radix\") {","        decreasing <- rep_len(as.logical(decreasing), length(z))","        return(.Internal(radixsort(na.last, decreasing, FALSE, ","            TRUE, ...)))","    }","    if (any(diff((l.z <- lengths(z)) != 0L))) ","        stop(\"argument lengths differ\")","    na <- vapply(z, is.na, rep.int(NA, l.z[1L]))","    ok <- if (is.matrix(na)) ","        rowSums(na) == 0L","    else !any(na)","    if (all(!ok)) ","        return(integer())","    z[[1L]][!ok] <- NA","    ans <- do.call(\"order\", c(z, list(decreasing = decreasing)))","    ans[ok[ans]]","}"],"has_legend":false,"has_inputs":false,"input_type":{},"input_email":{},"input_csv_vars":{},"input_api":{},"gaID":{},"split_layout":false,"split_aspect":{},"keySig":"68ffd3e3618dee5a8dd61de1f8208950","cogInterface":{"name":"by_H","group":"common","type":"JSON"},"panelInterface":{"type":"image"},"imgSrcLookup":{},"cogInfo":{"H":{"name":"H","desc":"conditioning variable","type":"factor","group":"condVar","defLabel":true,"defActive":true,"filterable":true,"log":null,"levels":["N003B1GRAD — GRADY MEMORIAL HOSPITAL-ATLANTA","N003B1SCOT — CHILDREN'S HEALTHCARE OF ATLANTA-SCOTTISH RITE","N0041074 — BOSTON MEDICAL CENTER","N009N8DHMC — DENVER HEALTH MEDICAL CENTER","N009N8UCMC — UCHEALTH UNIVERSITY OF COLORADO HOSPITAL","N0122420 — WAKE FOREST BAPTIST MEDICAL CENTER","N017EUCL — MAYO CLINIC HEALTH SYSTEM EAU CLAIRE","N020B5STAH — SAINT ALPHONSUS MEDICAL GROUP NAMPA","N020S98DRM — ST GEORGE REGIONAL MEDICAL CENTER","N020S98MDH — MCKAY-DEE HOSPITAL CENTER","N020S98UVR — UTAH VALLEY HOSPITAL","N021P00001 — OHSU HOSPITAL","N022XAG — LEHIGH VALLEY CEDAR CREST","N024000425 — UNIVERSITY OF LOUISVILLE HOSPITAL ULH","N02920010 — ECU HEALTH","N02933025 — NAVAL MEDICAL CENTER PORTSMOUTH","N029CHIPEN — HCA-CHIPPENHAM HOSPITAL","N030B12001 — GEISINGER MEDICAL CENTER - DANVILLE","N030B48001 — GEISINGER WYOMING VALLEY MEDICAL CENTER","N038B7RILE — METHODIST HOSPITAL"]},"panelKey":{"name":"panelKey","desc":"panel key","type":"key","group":"panelKey","defLabel":false,"defActive":true,"filterable":false,"log":null},"customer_cd":{"name":"customer_cd","desc":"customer_cd","type":"factor","group":"_data","defLabel":false,"defActive":true,"filterable":true,"log":null,"levels":["N003B1GRAD","N003B1SCOT","N0041074","N009N8DHMC","N009N8UCMC","N0122420","N017EUCL","N020B5STAH","N020S98DRM","N020S98MDH","N020S98UVR","N021P00001","N022XAG","N024000425","N02920010","N02933025","N029CHIPEN","N030B12001","N030B48001","N03